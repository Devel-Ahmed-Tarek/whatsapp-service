# انسخ الملف إلى .env وعدّل القيم
# copy .env.example .env

PORT=3000

# ويب هوك الرسائل الواردة (POST JSON). فاضي = مفيش نداءات للهوك
WHATSAPP_INCOMING_WEBHOOK_URL=http://whatsapp-code-solutions.test/api/whatsapp/webhooks/incoming

# تعطيل الهوك بالكامل (0 أو false) حتى لو الرابط موجود
# WHATSAPP_WEBHOOK_ENABLED=0

# بديل لنفس المتغير أعلاه
# INCOMING_WEBHOOK_URL=

# وضع تجريبي بدون واتساب حقيقي
# MOCK_WHATSAPP=1

# أقصى وقت يظل فيه طلب GET /qr مفتوحاً (افتراضي 15 ث) — العميل يعيد الطلب بعد pollAfterMs
# QR_HTTP_WAIT_MS=20000
# انتظار طويل في طلب واحد: ?longPoll=1 أو ضبط QR_LONG_POLL_MS (افتراضي 120000؛ QR_WAIT_TIMEOUT_MS ما زال يُقبل كاسم قديم)
# QR_LONG_POLL_MS=120000

# لا تفتح جلسة default عند تشغيل السيرفر (يوفر رام إذا بتستخدم sessionId مخصص فقط)
# WHATSAPP_SKIP_DEFAULT_SESSION=1

# تسلسل تشغيل كروم بين الجلسات (مفيد لو عدة sessionIds في نفس اللحظة — يقلل ضغط الجهاز)
# WHATSAPP_SERIALIZE_BROWSER_INIT=1

# دوكر/لينكس فقط غالباً: PUPPETEER_DISABLE_DEV_SHM=1
# مسار كروم يدوي (اختياري): PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# أعلام إضافية مفصولة بمسافة: PUPPETEER_EXTRA_ARGS=--disable-extensions
